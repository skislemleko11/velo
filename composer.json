{
  "name": "skislemleko11/velo",
  "description": "Fast and easy to learn tiny MVC framework",
  "type": "library",
  "license": "LGPL-3.0",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": ">=8.5",
    "ext-pdo": "*",
    "skislemleko11/velo-container": "*",
    "skislemleko11/velo-database": "*",
    "skislemleko11/velo-http": "*",
    "skislemleko11/velo-logger": "*",
    "skislemleko11/velo-router": "*"
  },
  "autoload": {
    "psr-4": {
      "Velo\\": "src/",
      "Velo\\Container\\": "packages/container/src/",
      "Velo\\Database\\": "packages/database/src/",
      "Velo\\Http\\": "packages/http/src/",
      "Velo\\Logger\\": "packages/logger/src/",
      "Velo\\Router\\": "packages/router/src/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^13"
  },
  "autoload-dev": {
    "psr-4": {
      "Velo\\Tests\\": "tests/",
      "Velo\\Container\\Tests\\": "packages/container/tests/",
      "Velo\\Database\\Tests\\": "packages/database/tests/",
      "Velo\\Http\\Tests\\": "packages/http/tests/",
      "Velo\\Logger\\Tests\\": "packages/logger/tests/",
      "Velo\\Router\\Tests\\": "packages/router/tests/",
      "Velo\\Playground\\": "playground/src/"
    }
  }
}
