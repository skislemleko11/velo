{
  "name": "skislemleko11/velo",
  "description": "Fast and easy to learn tiny MVC framework",
  "type": "library",
  "version": "1.0.0",
  "license": "LGPL-3.0",
  "repositories": [
    {
      "type": "path",
      "url": "packages/*",
      "options": {
        "symlink": true
      }
    }
  ],
  "require": {
    "php": ">=8.5",
    "vlucas/phpdotenv": "^5.6.3",
    "velo/container": "*",
    "velo/database": "*",
    "velo/http": "*",
    "velo/logger": "*",
    "velo/router": "*"
  },
  "autoload": {
    "psr-4": {
      "Velo\\": "src/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^13"
  },
  "autoload-dev": {
    "psr-4": {
      "Velo\\Tests\\": "tests/"
    }
  }
}
