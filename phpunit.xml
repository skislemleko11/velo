<?xml version="1.0" encoding="UTF-8" ?>
<phpunit colors="true" bootstrap="vendor/autoload.php" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         testdox="false"
         displayDetailsOnIncompleteTests="true"
         displayDetailsOnSkippedTests="true"
         displayDetailsOnTestsThatTriggerDeprecations="true"
         displayDetailsOnTestsThatTriggerErrors="true"
         displayDetailsOnTestsThatTriggerNotices="true"
         displayDetailsOnTestsThatTriggerWarnings="true"
>
    <testsuites>
        <testsuite name="Application Test Suite">
            <directory>tests</directory>
        </testsuite>
        <testsuite name="Container Test Suite">
            <directory>packages/container/tests</directory>
        </testsuite>
        <testsuite name="Database Test Suite">
            <directory>packages/database/tests</directory>
        </testsuite>
        <testsuite name="Http Test Suite">
            <directory>packages/http/tests</directory>
        </testsuite>
        <testsuite name="Logger Test Suite">
            <directory>packages/logger/tests</directory>
        </testsuite>
        <testsuite name="Router Test Suite">
            <directory>packages/router/tests</directory>
        </testsuite>
    </testsuites>
</phpunit>